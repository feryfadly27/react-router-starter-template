{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "kuesioner-rme-jambi",
	"main": "./workers/app.ts",
	"compatibility_date": "2025-10-08",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true,
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "kuesioner-rme-db",
			"database_id": "ee8a1afb-36e1-49d2-a114-a33be5e724dd"
		}
	],
	"r2_buckets": [
		{
			"binding": "SIGNATURES",
			"bucket_name": "kuesioner-signatures"
		}
	]
}
